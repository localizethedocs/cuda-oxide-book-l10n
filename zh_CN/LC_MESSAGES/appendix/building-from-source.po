msgstr ""

#: ../../../appendix/building-from-source.md:0
msgid "`nightly-2026-04-03` (pinned)"
msgstr ""

#: ../../../appendix/building-from-source.md:0
msgid "Compiler toolchain with `rustc-dev` for the codegen backend"
msgstr ""

