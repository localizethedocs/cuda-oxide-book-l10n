msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:168
msgid "tcgen05 uses two descriptors per MMA instruction:"
msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:170
msgid "**Instruction descriptor** — encodes the MMA configuration:"
msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:172
msgid ""
"use cuda_device::tcgen05::{\n"
"    Tcgen05InstructionDescriptor,\n"
"    Tcgen05ElementType,\n"
"    Tcgen05MmaShape,\n"
"};\n"
"\n"
"let idesc = Tcgen05InstructionDescriptor::builder()\n"
"    .shape(Tcgen05MmaShape::M128_N128)\n"
"    .a_type(Tcgen05ElementType::F16)\n"
"    .b_type(Tcgen05ElementType::F16)\n"
"    .build();\n"
msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:186
msgid "**SMEM descriptor** — points to the operand tile in shared memory:"
msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:188
msgid ""
"use cuda_device::tcgen05::{Tcgen05SmemDescriptor, Tcgen05SwizzleMode};\n"
"\n"
"let a_desc = Tcgen05SmemDescriptor::for_k_major(\n"
"    smem_a_addr,\n"
"    m, k,\n"
"    2, // bytes per element (f16)\n"
"    Tcgen05SwizzleMode::Swizzle128B,\n"
");\n"
msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:199
msgid "Issuing MMA"
msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:201
msgid ""
"One thread issues the MMA instruction, then all threads wait on a barrier:"
msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:204
msgid ""
"use cuda_device::tcgen05::{tcgen05_mma_f16, tcgen05_commit};\n"
"\n"
"if thread::threadIdx_x() == 0 {\n"
"    unsafe {\n"
"        tcgen05_mma_f16(\n"
"            tmem.raw_address(),\n"
"            a_desc.raw(),\n"
"            b_desc.raw(),\n"
"            idesc.raw(),\n"
"            true, // enable accumulation into D\n"
"        );\n"
"        tcgen05_commit(mma_barrier_ptr);\n"
"    }\n"
"}\n"
"\n"
"// All threads wait for MMA completion\n"
"mma_barrier.wait(token);\n"
msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:224
msgid "Epilog — reading results from TMEM"
msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:226
msgid ""
"After the MMA loop, the accumulator lives in TMEM. To move it to shared "
"memory (for a subsequent TMA store to global), you load from TMEM into "
"registers and then use `stmatrix` to write to shared memory:"
msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:230
msgid ""
"use cuda_device::tcgen05::{\n"
"    cvt_f32x2_bf16x2,\n"
"    tcgen05_ld_16x256b_pure,\n"
"    tcgen05_load_wait,\n"
"    stmatrix_m8n8_x2,\n"
"    TmemF32x4,\n"
"};\n"
"\n"
"unsafe {\n"
"    // Load a 16×256-bit slice from TMEM into registers\n"
"    let regs: TmemF32x4 = tcgen05_ld_16x256b_pure(tmem.raw_address());\n"
"    tcgen05_load_wait();\n"
"\n"
"    // Convert four f32 accumulators into two registers of packed bf16 "
"values.\n"
"    let packed0 = cvt_f32x2_bf16x2(regs[0], regs[1]);\n"
"    let packed1 = cvt_f32x2_bf16x2(regs[2], regs[3]);\n"
"\n"
"    // Store two 8×8 matrices from registers (warp-collective).\n"
"    stmatrix_m8n8_x2(smem_ptr, packed0, packed1);\n"
"}\n"
msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:253
msgid ""
"`stmatrix` is a warp-collective operation — all 32 threads participate, each "
"contributing its register slice to form the shared memory tile."
msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:256
msgid "CTA-group-2 (CG2)"
msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:258
msgid ""
"Blackwell also supports **CG2 mode**, where two CTAs (from a cluster) issue "
"MMA instructions that are coordinated as a pair. This doubles the effective "
"tile width and requires the `_cg2` API variants:"
msgstr ""

#: ../../../advanced/matrix-multiply-accelerators.md:262
