msgstr ""

#: ../../../compiler/pliron.md:0
msgid "**LLVM dialect**"
msgstr ""

#: ../../../compiler/pliron.md:0
msgid "Machine-near operations -- integer math, memory, control flow"
msgstr ""

#: ../../../compiler/pliron.md:0
