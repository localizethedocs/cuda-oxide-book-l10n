#: ../../../appendix/api-quick-reference.md:136
msgid ""
"use cuda_device::{DisjointSlice, kernel};\n"
"\n"
"#[kernel]\n"
"pub fn vecadd(a: &[f32], b: &[f32], mut c: DisjointSlice<f32>) {\n"
"    if let Some((c_elem, idx)) = c.get_mut_indexed() {\n"
"        let i = idx.get();\n"
"        *c_elem = a[i] + b[i];\n"
"    }\n"
"}\n"
msgstr ""

