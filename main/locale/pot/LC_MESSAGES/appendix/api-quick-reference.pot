#: ../../../appendix/api-quick-reference.md:322
msgid ""
"use cuda_device::cluster;\n"
"\n"
"let rank = cluster::block_rank();        // This block's rank in the "
"cluster\n"
"let size = cluster::cluster_size();      // Number of blocks in cluster\n"
"cluster::cluster_sync();                 // Barrier across all cluster "
"blocks\n"
"\n"
"// Distributed Shared Memory\n"
"let remote_ptr = cluster::map_shared_rank(local_ptr, target_rank);\n"
"let val = cluster::dsmem_read_u32(remote_ptr);\n"
msgstr ""

#: ../../../appendix/api-quick-reference.md:336
msgid "Tensor Cores — WGMMA (Hopper, SM 90)"
msgstr ""

#: ../../../appendix/api-quick-reference.md:338
msgid ""
"use cuda_device::wgmma;\n"
"\n"
"wgmma::wgmma_fence();\n"
"wgmma::wgmma_commit_group();\n"
"wgmma::wgmma_wait_group::<0>();\n"
msgstr ""

#: ../../../appendix/api-quick-reference.md:346
msgid ""
"Warpgroup MMA: 4 warps (128 threads) issue matrix multiply-accumulate from "
"shared memory. Operands described by SMEM descriptors; accumulator in "
"registers."
msgstr ""

#: ../../../appendix/api-quick-reference.md:351
msgid "Tensor Cores — tcgen05 (Blackwell, SM 100+)"
msgstr ""

#: ../../../appendix/api-quick-reference.md:353
msgid ""
"use cuda_device::tcgen05::{TmemGuard, TmemUninit, TmemReady};\n"
"use cuda_device::SharedArray;\n"
"\n"
"static mut TMEM_SLOT: SharedArray<u32, 1, 4> = SharedArray::UNINIT;\n"
"\n"
"let guard = TmemGuard::<TmemUninit, 512>::from_static(&raw mut TMEM_SLOT as "
"*mut u32);\n"
"let guard = unsafe { guard.alloc() };   // TmemUninit → TmemReady\n"
"// ... issue MMA, read results via guard.address() ...\n"
"let _guard = unsafe { guard.dealloc() }; // TmemReady → TmemDeallocated\n"
msgstr ""

#: ../../../appendix/api-quick-reference.md:365
msgid ""
"Single-thread MMA issue into dedicated Tensor Memory (TMEM). `TmemGuard` "
"manages TMEM lifetime with typestate: `TmemUninit → TmemReady → "
"TmemDeallocated`. N_COLS must be a power of 2 in the range [32, 512]."
msgstr ""

#: ../../../appendix/api-quick-reference.md:371
msgid "Host-Side: Kernel Launch"
msgstr ""

#: ../../../appendix/api-quick-reference.md:373
msgid "Typed Synchronous"
msgstr ""

#: ../../../appendix/api-quick-reference.md:375
msgid ""
"use cuda_core::{CudaContext, DeviceBuffer, LaunchConfig};\n"
"\n"
"let ctx = CudaContext::new(0).unwrap();\n"
"let stream = ctx.default_stream();\n"
"let module = kernels::load(&ctx).unwrap();\n"
"\n"
"let a = DeviceBuffer::from_host(&stream, &a_host).unwrap();\n"
"let b = DeviceBuffer::from_host(&stream, &b_host).unwrap();\n"
"let mut output = DeviceBuffer::<f32>::zeroed(&stream, n).unwrap();\n"
"\n"
"// SAFETY: this is a 1D launch and all buffers contain n elements.\n"
"unsafe {\n"
"    module.vecadd(&stream, LaunchConfig::for_num_elems(n), &a, &b, &mut "
"output)\n"
"}\n"
".unwrap();\n"
msgstr ""

#: ../../../appendix/api-quick-reference.md:393
msgid "Typed Async"
msgstr ""

#: ../../../appendix/api-quick-reference.md:395
msgid ""
"use cuda_async::device_operation::DeviceOperation;\n"
"\n"
"let module = kernels::load_async(0)?;\n"
"// SAFETY: this is 1D, buffers contain n elements, and module/scheduler "
"share a context.\n"
"let op = unsafe {\n"
"    module.vecadd_async(LaunchConfig::for_num_elems(n), &a, &b, &mut "
"output)\n"
"}?;\n"
"\n"
"op.sync()?;       // blocking\n"
"// or: op.await?;  // async with tokio\n"
msgstr ""

#: ../../../appendix/api-quick-reference.md:408
msgid ""
"Raw generated calls are unsafe because `LaunchConfig` is not tied to a "
"kernel. A kernel with `#[launch_contract]` instead uses "
"`LaunchConfig1D/2D/3D` to create a checked `PreparedLaunch<K>`, then "
"launches safely. `cuda_launch!` and `cuda_launch_async!` remain unsafe lower-"
"level APIs for explicit module loading and custom launch code."
msgstr ""

