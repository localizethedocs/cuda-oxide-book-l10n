msgstr ""

#: ../../../gpu-safety/the-safety-model.md:0
msgid "Caller asserts every thread used the same `s`"
msgstr ""

#: ../../../gpu-safety/the-safety-model.md:0
msgid "`index_2d_row()`"
msgstr ""

#: ../../../gpu-safety/the-safety-model.md:0
