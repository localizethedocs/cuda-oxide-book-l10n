#: ../../../gpu-programming/closures-and-generics.md:186
msgid "Move vs reference closures"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:188
msgid "The `move` keyword determines how captures are transferred to the GPU:"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:190
msgid "Move closures (recommended default)"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:192
msgid ""
"let factor = 3i32;\n"
"move |x| x * factor   // `factor` is copied into the closure struct\n"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:197
msgid "The closure struct holds the capture by value (`{ factor: i32 }`)."
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:198
msgid "The kernel reads `factor` as a regular field of the byval closure."
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:199
msgid "The host variable can be dropped after launch."
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:200
msgid "Works on all systems -- no special hardware support needed."
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:202
msgid "Reference closures (HMM)"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:204
msgid ""
"let factor = 3i32;\n"
"|x| x * factor   // closure captures &factor\n"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:209
msgid ""
"The closure struct contains a **host pointer** to `factor` (`{ factor: &i32 }"
"`)."
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:211
msgid ""
"The whole closure still travels as one byval parameter; the kernel deref's "
"that host pointer through **Hardware-Managed Memory (HMM)**, which migrates "
"the host page on access."
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:214
msgid "The host variable **must remain alive** until the kernel completes."
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:215
msgid "Requires HMM support (Turing+ GPU, Linux 6.1.24+, CUDA 12.2+)."
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:217
msgid "When to use which"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:0
msgid "Scenario"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:0
msgid "Use"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:0
msgid "Small scalar captures (numbers, booleans)"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:0
msgid "`move` (zero-copy overhead)"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:0
msgid "Large struct captures"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:0
msgid "`move` if the kernel reads it many times; HMM if rarely accessed"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:0
msgid "Prototyping"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:0
msgid "Either works; `move` is more portable"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:0
msgid "Shared mutable state between host and device"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:0
msgid "Reference (HMM) -- but beware synchronization"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:227
msgid ""
"When in doubt, use `move` closures. They are simpler to reason about, work "
"everywhere, and avoid the synchronization hazards of shared host/device "
"memory."
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:231
msgid "In-kernel closures"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:233
msgid ""
"Closures defined and called entirely within device code work with normal "
"Rust semantics -- no host/device ABI is involved because everything is "
"already on the GPU:"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:237
msgid ""
"#[kernel]\n"
"pub fn apply_transform(input: &[f32], mut out: DisjointSlice<f32>) {\n"
"    let idx = thread::index_1d();\n"
"\n"
"    let transform = |x: f32| -> f32 {\n"
"        let clamped = if x < 0.0 { 0.0 } else if x > 1.0 { 1.0 } else "
"{ x };\n"
"        clamped * clamped\n"
"    };\n"
"\n"
"    if let Some(out_elem) = out.get_mut(idx) {\n"
"        *out_elem = transform(input[idx.get()]);\n"
"    }\n"
"}\n"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:253
msgid ""
"In-kernel closures are inlined by the compiler and have zero overhead. They "
"are useful for factoring logic within a kernel without introducing a "
"separate device function."
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:257
msgid "Cross-crate kernels"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:259
msgid ""
"Kernels can be defined in a library crate and launched from a binary crate:"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:261
msgid ""
"// In lib crate `my_kernels`:\n"
"use cuda_device::{cuda_module, kernel, thread, DisjointSlice};\n"
"\n"
"#[cuda_module]\n"
"pub mod kernels {\n"
"    use super::*;\n"
"\n"
"    #[kernel]\n"
"    pub fn vecadd(a: &[f32], b: &[f32], mut c: DisjointSlice<f32>) {\n"
"        let idx = thread::index_1d();\n"
"        let i = idx.get();\n"
"        if let Some(c_elem) = c.get_mut(idx) {\n"
"            *c_elem = a[i] + b[i];\n"
"        }\n"
"    }\n"
"}\n"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:280
msgid ""
"// In binary crate:\n"
"use my_kernels::kernels;\n"
"\n"
"let module = kernels::load(&ctx)?;\n"
"// SAFETY: config is 1D and all three buffers cover every launched index.\n"
"unsafe { module.vecadd(&stream, config, &a, &b, &mut c) }\n"
"    .expect(\"Launch failed\");\n"
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:290
msgid ""
"The compiler handles cross-crate kernel discovery through the marker traits "
"generated by `#[kernel]`. The typed module resolves the PTX name at compile "
"time and caches the loaded function handle."
msgstr ""

#: ../../../gpu-programming/closures-and-generics.md:295
msgid ""
"For generic cross-crate kernels, the monomorphization happens in the "
"**calling** crate (where the concrete type is known), so the PTX is "
"generated as part of the binary's compilation."
msgstr ""
